---
import Layout from '../../layouts/Layout.astro';
import { DashboardShell } from '../../components/DashboardShell';
import { ReclamoForm } from '../../components/Reclamos/ReclamoForm';
import { AuthProvider } from '../../components/AuthProvider';
---

<Layout title="Reclamos e Incidencias | Cimasur">
  <AuthProvider client:only="react">
    <DashboardShell title="Control de Calidad Post-Venta" client:load>
      <div class="mb-6">
        <a href="/dashboard" class="text-slate-500 hover:text-white text-sm">← Volver</a>
      </div>
      <ReclamoForm client:load />
    </DashboardShell>
  </AuthProvider>
</Layout>