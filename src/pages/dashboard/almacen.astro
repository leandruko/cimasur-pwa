---
import Layout from '../../layouts/Layout.astro';
import { DashboardShell } from '../../components/DashboardShell';
import { AlmacenForm } from '../../components/Almacen/AlmacenForm';
import { AuthProvider } from '../../components/AuthProvider';
---

<Layout title="Control de Almacén | Cimasur">
  <AuthProvider client:only="react">
    <DashboardShell title="Logística y Almacenamiento" client:only="react">
      <div class="mb-6">
        <a href="/dashboard" class="text-slate-500 hover:text-white text-sm">← Volver</a>
      </div>
      <AlmacenForm client:only="react" />
    </DashboardShell>
  </AuthProvider>
</Layout>