---
import Layout from '../../layouts/Layout.astro';
import { DashboardShell } from '../../components/DashboardShell';
import { VentaForm } from '../../components/Ventas/VentaForm';
import { AuthProvider } from '../../components/AuthProvider';
---

<Layout title="Registro de Ventas | Cimasur">
  <AuthProvider client:only="react">
    <DashboardShell title="Gestión de Despachos" client:load>
      <div class="mb-6">
        <a href="/dashboard" class="text-slate-500 hover:text-white text-sm">← Volver</a>
      </div>
      <VentaForm client:load />
    </DashboardShell>
  </AuthProvider>
</Layout>