---
import Layout from '../../layouts/Layout.astro';
import { DashboardShell } from '../../components/DashboardShell';
import { GridActions } from '../../components/Dashboard/GridActions';
import { AuthProvider } from '../../components/AuthProvider';

---

<Layout title="Panel de Trazabilidad">
  <AuthProvider client:only="react">
    <DashboardShell title="Centro de Operaciones Cimasur" client:load>
      <div class="mb-8 p-4 bg-blue-900/10 border border-blue-500/20 rounded-lg">
        <p class="text-blue-400 text-sm">
          <strong>Modo Operativo:</strong> Seleccione un módulo para iniciar un registro. 
          Los datos se sincronizan automáticamente al detectar conexión.
        </p>
      </div>
      
      <GridActions client:load />
    </DashboardShell>
  </AuthProvider>
</Layout>