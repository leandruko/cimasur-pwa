---
import Layout from '../../layouts/Layout.astro';
import { DashboardShell } from '../../components/DashboardShell';
import { EtiquetadoForm } from '../../components/Etiquetado/EtiquetadoForm';
import { AuthProvider } from '../../components/AuthProvider';
---

<Layout title="Etiquetado y QA | Cimasur">
  <AuthProvider client:only="react">
    <DashboardShell title="Control de Calidad" client:load>
      <div class="mb-6">
        <a href="/dashboard" class="text-slate-500 hover:text-white text-sm">← Volver al Menú</a>
      </div>
      <EtiquetadoForm client:load />
    </DashboardShell>
  </AuthProvider>
</Layout>