---
import Layout from '../../layouts/Layout.astro';
import { DashboardShell } from '../../components/DashboardShell';
import { OrdenForm } from '../../components/OrdenForm';
import { supabase } from '../../lib/supabase';

// Obtenemos la sesión para pasarle el ID del técnico al componente React
const { data: { session } } = await supabase.auth.getSession();
const tecnicoId = session?.user.id;
---

<Layout title="Nueva Orden">
  <DashboardShell title="Nuevo Registro Industrial" client:load>
    <div class="mb-8">
      <a href="/dashboard" class="text-blue-500 hover:underline">← Volver al listado</a>
    </div>
    
    <div class="flex justify-center">
      <OrdenForm tecnicoId={tecnicoId} client:load />
    </div>
  </DashboardShell>
</Layout>